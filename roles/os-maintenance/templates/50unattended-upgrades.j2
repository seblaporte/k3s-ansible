// Security updates only — full OS upgrades are handled by playbook/os-upgrade.yml
// Auto-reboot is disabled — use kured for rolling reboots (https://github.com/kubereboot/kured)

Unattended-Upgrade::Allowed-Origins {
    "Debian:${distro_codename}-security";
    "Raspbian:${distro_codename}";
};

// Kernel and firmware are excluded: nodes boot via NFS/iSCSI from Synology NAS.
// /boot/firmware is not locally mounted, so kernel post-install scripts fail.
Unattended-Upgrade::Package-Blacklist {
    "linux-image-*";
    "linux-headers-*";
    "linux-libc-dev";
    "raspi-firmware";
    "raspi-config";
};

Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Remove-New-Unused-Dependencies "true";

// Reboot is managed by kured — it watches /var/run/reboot-required and does a rolling drain/reboot
Unattended-Upgrade::Automatic-Reboot "false";
